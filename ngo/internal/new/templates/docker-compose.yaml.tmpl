services:
  app:
    build:
      context: ../../
      dockerfile: build/Dockerfile
    ports:
      - "4000:4000"
    env_file:
      - .env
    environment:
      - ENVIRONMENT=development
      - ADDRESS=:4000
{{- if .ShouldAddDb}}
      - GOOSE_DBSTRING=postgres://postgres:postgres@postgres:5432/{{.Name}}?sslmode=disable
      - GOOSE_DRIVER=postgres
      - GOOSE_MIGRATION_DIR=./internal/infra/migrations
{{- end}}
{{- if .ShouldAddRedis}}
      - REDIS_URL=redis://redis:6379/0
{{- end}}
{{- if .ShouldAddSecret}}
      - JWT_SECRET=${JWT_SECRET}
{{- end}}
{{- if or .ShouldAddDb .ShouldAddRedis}}
    depends_on:
{{- if .ShouldAddDb}}
      postgres:
        condition: service_healthy
{{- end}}
{{- if .ShouldAddRedis}}
      redis:
        condition: service_healthy
{{- end}}
{{- end}}
{{- if .ShouldAddDb}}

  postgres:
    image: postgres:17-alpine
    ports:
      - "5433:5432"
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      - POSTGRES_DB={{.Name}}
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
{{- end}}
{{- if .ShouldAddRedis}}

  redis:
    image: redis:8-alpine
    ports:
      - "6380:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5
{{- end}}
{{- if .ShouldAddDb}}

volumes:
  pgdata:
{{- end}}
