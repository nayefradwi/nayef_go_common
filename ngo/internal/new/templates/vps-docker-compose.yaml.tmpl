name: {{ .Name }}
services:
  {{ .Name }}:
    build:
      context: ../../
      dockerfile: build/Dockerfile
    env_file:
      - .env
    environment:
      - ENVIRONMENT={{ .Environment }}
      - ADDRESS=${ADDRESS}
{{- if .ShouldAddDb}}
      - GOOSE_DBSTRING=${GOOSE_DBSTRING}
      - GOOSE_DRIVER=postgres
      - GOOSE_MIGRATION_DIR=./internal/infra/migrations
{{- end}}
{{- if .ShouldAddRedis}}
      - REDIS_URL=${REDIS_URL}
{{- end}}
{{- if .ShouldAddSecret}}
      - JWT_SECRET=${JWT_SECRET}
{{- end}}
{{- if or .ShouldAddDb .ShouldAddRedis}}
    depends_on:
{{- if .ShouldAddDb}}
      {{ .Name }}_postgres:
        condition: service_healthy
{{- end}}
{{- if .ShouldAddRedis}}
      {{ .Name }}_redis:
        condition: service_healthy
{{- end}}
{{- end}}
{{- if .ShouldAddDb}}

  {{ .Name }}_postgres:
    image: postgres:17-alpine
    environment:
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - POSTGRES_DB=${POSTGRES_DB}
    volumes:
      - {{ .Name }}pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5
{{- end}}
{{- if .ShouldAddRedis}}

  {{ .Name }}_redis:
    image: redis:8-alpine
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5
{{- end}}
{{- if .ShouldAddDb}}

volumes:
  {{ .Name }}pgdata:
{{- end}}
