ENVIRONMENT="development"
{{if .ShouldAddDb}}
GOOSE_DRIVER=postgres
GOOSE_MIGRATION_DIR=./internal/infra/migrations
GOOSE_DBSTRING="postgres://<user>:<password>@<host>:<port>/<db>"
{{end}}
{{if .ShouldAddRedis}}
REDIS_URL="redis://<user>:<password>@<host>:<port>/<db>"
{{end}}
{{if .ShouldAddSecret}}
JWT_SECRET=""
{{end}}
